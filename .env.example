# ── Core dashboard note ───────────────────────────────────────────────────────
# The main live dashboard can run without Supabase or Telegram.
# Only add the optional keys below if you want persistence or alerts.

# ── Supabase (optional) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # only needed for write routes like /api/trading/signal
POSTGRES_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_DRY_RUN=true                        # set false for live alerts

# ── Trading (optional overrides) ──────────────────────────────────────────────
TRADING_DRY_RUN=true                         # set false for live order execution
INITIAL_CAPITAL=500000
